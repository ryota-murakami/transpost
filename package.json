{
  "name": "transpost",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "X(Twitter)の日本語下書きを英訳＋日本語解説して右側パネルに表示するChrome拡張（英語学習用）",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "wxt": "0.20.26"
  }
}
